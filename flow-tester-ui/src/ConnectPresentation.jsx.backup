// SLIDE 4: DOMAIN LOCKS
// ═══════════════════════════════════════════════════════════════════

function DomainLocksSlide({ visible }) {
  const domains = [
    {
      name: "Customer Profiles",
      icon: "👤",
      color: palette.accent,
      constraint: "1 domain / instance",
      impact: "All tenant PII pools into one domain. Identity Resolution merges duplicates across tenants. No TBAC on profile data.",
    },
    {
      name: "Amazon Connect Cases",
      icon: "📁",
      color: palette.warn,
      constraint: "1 Cases domain / instance",
      impact: "All case templates, fields, layouts shared. DWP benefits cases and NHS safeguarding cases in the same domain.",
    },
    {
      name: "Amazon Q in Connect",
      icon: "🧠",
      color: palette.success,
      constraint: "1 AI agent domain / instance",
      impact: "One knowledge base feeds all agents. HMRC tax guidance and NHS clinical pathways cannot be separated.",
    },
    {
      name: "Outbound Campaigns",
      icon: "📞",
      color: palette.home,
      constraint: "Instance + account quotas",
      impact: "Campaign management and predictive dialer shared. One tenant's burst exhausts quotas for all.",
    },
    {
      name: "Evaluation Forms",
      icon: "📝",
      color: "#fb7185",
      constraint: "Instance-wide",
      impact: "Performance evaluations shared. Supervisors see all agents' evaluations. Gen AI auto-evals process all contacts.",
    },
    {
      name: "Agent Scheduling",
      icon: "📅",
      color: "#38bdf8",
      constraint: "Instance-level",
      impact: "Scheduling rules, shift profiles, staffing forecasts at instance level. Cross-tenant pools break forecasting.",
    },
  ];

  return (
    <SlideContainer visible={visible}>
      <GlowOrb color="#fb7185" size={400} top={-100} left="30%" opacity={0.06} />
      
      <SectionHeader
        badge="1:1 Domain Locks"
        badgeColor="#fb7185"
        title="One Instance ="
        highlight="One Domain Each"
        highlightColor="#fb7185"
        subtitle="Six critical services hard-locked to a single domain per instance — no tenant partitioning"
      />
      
      <div style={{ maxWidth: 720, margin: "0 auto", position: "relative", zIndex: 1 }}>
        {/* Lock indicator */}
        <div
          style={{
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            gap: 10,
            marginBottom: 24,
            padding: "12px 20px",
            borderRadius: 14,
            background: `rgba(251, 113, 133, 0.06)`,
            border: `1px solid rgba(251, 113, 133, 0.2)`,
          }}
        >
          <span style={{ fontSize: 22 }}>🔒</span>
          <span
            style={{
              fontSize: 11,
              color: "#fb7185",
              fontWeight: 700,
              fontFamily: typography.mono,
              letterSpacing: "0.03em",
            }}
          >
            1 INSTANCE = 1 Profiles = 1 Cases = 1 Q = 1 Scheduling Domain
          </span>
        </div>
        
        <div
          style={{
            display: "grid",
            gridTemplateColumns: "repeat(auto-fit, minmax(320px, 1fr))",
            gap: 12,
          }}
        >
          {domains.map((d, i) => (
            <GlassPanel
              key={d.name}
              accent={d.color}
              padding={18}
              style={{ animation: `slideUp 400ms ${easing.outExpo} ${i * 60}ms backwards` }}
            >
              <div style={{ display: "flex", alignItems: "flex-start", gap: 12, marginBottom: 10 }}>
                <span style={{ fontSize: 24 }}>{d.icon}</span>
                <div style={{ flex: 1 }}>
                  <div style={{ fontSize: 14, fontWeight: 700, color: d.color, fontFamily: typography.display }}>
                    {d.name}
                  </div>
                  <Badge color={palette.danger} size="xs">
                    {d.constraint}
                  </Badge>
                </div>
              </div>
              <p style={{ fontSize: 12, color: palette.textSecondary, lineHeight: 1.6, margin: 0, fontFamily: typography.body }}>
                {d.impact}
              </p>
            </GlassPanel>
          ))}
        </div>
        
        <div
          style={{
            marginTop: 20,
            padding: "16px 20px",
            borderRadius: 14,
            background: `linear-gradient(135deg, rgba(251, 113, 133, 0.08), ${palette.dangerDim})`,
            border: `1px solid rgba(251, 113, 133, 0.25)`,
            textAlign: "center",
          }}
        >
          <p style={{ fontSize: 13, color: palette.textSecondary, lineHeight: 1.7, margin: 0, fontFamily: typography.body }}>
            Each domain is a <strong style={{ color: palette.text }}>single flat namespace</strong>. NHS patient 
            profiles, HMRC taxpayer records, DWP benefits cases, and Home Office immigration data all inhabit 
            the same container.
          </p>
        </div>
      </div>
    </SlideContainer>
  );
}

