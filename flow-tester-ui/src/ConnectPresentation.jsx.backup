    },
    {
      title: "S3 Race Condition",
      color: palette.home,
      icon: "⏱️",
      desc: "Lambda pipeline must move recordings instantly. Any failure leaves data in shared bucket.",
      tag: "Data minimisation breach",
    },
    {
      title: "Kinesis / CloudWatch",
      color: palette.accent,
      icon: "📡",
      desc: "CTRs into shared Kinesis. CloudWatch logs all tenants. No tag-based filtering.",
