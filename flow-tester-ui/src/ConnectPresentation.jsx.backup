      icon: "🔓",
      desc: "Any admin with an unrestricted security profile bypasses all TBAC. One misconfiguration exposes every tenant.",
      tag: "NCSC Principle 3",
    },
    {
      title: "Contact Search Leakage",
      color: palette.warn,
      icon: "🔎",
      desc: "Contact Search returns cross-tenant results. NHS supervisor could surface HMRC conversations.",
