import { useState } from "react";

const C = {
  bg: "#0a0e1a", surface: "#111827", surfaceLight: "#1a2235",
  accent: "#00d4ff", accentDim: "#00d4ff33",
  danger: "#ff3b5c", dangerDim: "#ff3b5c22",
  success: "#00e68a", successDim: "#00e68a22",
  warn: "#ffb020", warnDim: "#ffb02022",
  purple: "#a78bfa", purpleDim: "#a78bfa22",
  rose: "#fb7185", roseDim: "#fb718522",
  teal: "#2dd4bf", tealDim: "#2dd4bf22",
  amber: "#f59e0b",
  slate: "#64748b",
  text: "#e2e8f0", textDim: "#94a3b8",
  border: "#1e293b", borderLight: "#334155",
};
const T = [
  { name: "HMRC", color: "#00d4ff", icon: "£" },
  { name: "NHS Digital", color: "#00e68a", icon: "+" },
  { name: "DWP", color: "#ffb020", icon: "◆" },
  { name: "Home Office", color: "#a78bfa", icon: "⬡" },
];
const SL = [
  { id: "hero", label: "Overview" }, { id: "shared", label: "Shared Instance" },
  { id: "tagging", label: "Tag Reality" }, { id: "domains", label: "Domain Locks" },
  { id: "gaps", label: "TBAC Gaps" }, { id: "ai", label: "AI Bundle" },
  { id: "technical", label: "Technical Path" }, { id: "business", label: "Business Decision" },
  { id: "faq", label: "FAQ" }, { id: "solution", label: "Per-Agency" },
];
const F = "'DM Sans', sans-serif";
const FH = "'Playfair Display', Georgia, serif";

function Badge({ children, color = C.accent }) {
  return <span style={{ display: "inline-block", padding: "3px 10px", borderRadius: 20, fontSize: 11, fontWeight: 700, letterSpacing: 0.8, color, border: `1px solid ${color}44`, background: `${color}15`, textTransform: "uppercase" }}>{children}</span>;
}
function Orb({ color, size = 200, top, left, opacity = 0.12 }) {
  return <div style={{ position: "absolute", top, left, width: size, height: size, borderRadius: "50%", filter: "blur(80px)", opacity, background: color, pointerEvents: "none", zIndex: 0 }} />;
}
function Pulse({ color }) {
  return <span style={{ display: "inline-block", width: 8, height: 8, borderRadius: "50%", background: color, marginRight: 8, verticalAlign: "middle", animation: "pulse 2s ease-in-out infinite" }} />;
}
function Sl({ visible, children }) {
  return <div style={{ opacity: visible ? 1 : 0, transition: "opacity 0.5s ease", position: visible ? "relative" : "absolute", pointerEvents: visible ? "auto" : "none", padding: "28px 20px", top: 0, left: 0, right: 0 }}>{children}</div>;
}
function SH({ badge, bc, title, hl, hc, sub }) {
  return (
    <div style={{ textAlign: "center", marginBottom: 26, position: "relative", zIndex: 1 }}>
      <Badge color={bc}>{badge}</Badge>
      <h2 style={{ fontSize: 30, fontWeight: 800, color: C.text, margin: "14px 0 6px", fontFamily: FH, lineHeight: 1.15 }}>
        {title} <span style={{ color: hc }}>{hl}</span>
      </h2>
      {sub && <p style={{ fontSize: 13, color: C.textDim, maxWidth: 560, margin: "0 auto", fontFamily: F, lineHeight: 1.5 }}>{sub}</p>}
    </div>
  );
}

// 1. HERO
  return (
    <Sl visible={v}>
      <Orb color={C.accent} size={400} top={-100} left={-100} opacity={0.07} />
      <Orb color={C.danger} size={300} top={200} left="60%" opacity={0.05} />
      <div style={{ textAlign: "center", padding: "50px 0 30px", position: "relative", zIndex: 1 }}>
        <Badge color={C.warn}>UK Government Risk Analysis</Badge>
        <h1 style={{ fontSize: 48, fontWeight: 800, color: C.text, margin: "22px 0 0", fontFamily: FH, lineHeight: 1.1, letterSpacing: -1 }}>Multi-Tenant<br /><span style={{ color: C.accent }}>Amazon Connect</span></h1>
        <p style={{ fontSize: 16, color: C.textDim, maxWidth: 540, margin: "18px auto 0", lineHeight: 1.6, fontFamily: F }}>How tag-based access controls, domain constraints, and the AI pricing toggle interact across sovereign government entities — and where isolation fails.</p>
        <div style={{ display: "flex", gap: 14, justifyContent: "center", marginTop: 40, flexWrap: "wrap" }}>
          {T.map((t, i) => (
            <div key={t.name} style={{ padding: "12px 20px", borderRadius: 12, border: `1px solid ${t.color}33`, background: `${t.color}08`, display: "flex", alignItems: "center", gap: 10, animation: `fadeUp 0.5s ease ${0.3 + i * 0.1}s both` }}>
              <span style={{ fontSize: 18, width: 30, height: 30, borderRadius: 8, display: "flex", alignItems: "center", justifyContent: "center", background: `${t.color}22`, color: t.color }}>{t.icon}</span>
              <span style={{ color: t.color, fontWeight: 600, fontSize: 13, fontFamily: F }}>{t.name}</span>
            </div>
          ))}
        </div>
        <p style={{ fontSize: 12, color: C.textDim, marginTop: 28, opacity: 0.5, fontFamily: F }}>4 independent data controllers · 1 shared instance · 6+ data repos · 1 domain each for Profiles, Cases, Q</p>
      </div>
    </Sl>
  );
}

// 2. SHARED INSTANCE
function S2({ v }) {
  const repos = [
    { name: "S3 Recordings", icon: "🪣", desc: "Call recordings & transcripts" },
    { name: "Contact Records", icon: "📋", desc: "CTRs via shared Kinesis" },
    { name: "Contact Lens", icon: "🔍", desc: "Analytics & sentiment" },
    { name: "Lex Sessions", icon: "🤖", desc: "Bot conversation logs" },
    { name: "DynamoDB", icon: "🗃️", desc: "Session state & config" },
    { name: "CloudWatch", icon: "📊", desc: "Metrics & ops logs" },
  ];

  return (
    <SlideContainer visible={visible}>
      <GlowOrb color={palette.danger} size={400} top={-80} right={-100} opacity={0.06} />
      
      <SectionHeader
        badge="Architecture Problem"
        badgeColor={palette.danger}
        title="One Instance,"
        highlight="Shared Everything"
        highlightColor={palette.danger}
        subtitle="All tenants' data flows into common AWS resources with no native isolation"
      />
      
      {/* Tenant row */}
      <div
        style={{
          display: "flex",
          justifyContent: "center",
          gap: 12,
          marginBottom: 8,
          flexWrap: "wrap",
          position: "relative",
          zIndex: 1,
        }}
      >
        {tenants.map((t, i) => (
          <div
            key={t.name}
            style={{
              padding: "10px 16px",
              borderRadius: 12,
              border: `1px solid ${t.color}33`,
              background: `${t.color}08`,
              textAlign: "center",
              minWidth: 90,
              animation: `slideUp 400ms ${easing.outExpo} ${i * 60}ms backwards`,
            }}
          >
            <div style={{ fontSize: 18, color: t.color, marginBottom: 4 }}>{t.icon}</div>
            <div style={{ fontSize: 11, fontWeight: 700, color: t.color, fontFamily: typography.body }}>
              {t.name}
            </div>
          </div>
        ))}
      </div>
      
      {/* Connection lines */}
      <div style={{ display: "flex", justifyContent: "center", margin: "8px 0", position: "relative", zIndex: 1 }}>
        {tenants.map((t, i) => (
          <div key={i} style={{ display: "flex", flexDirection: "column", alignItems: "center", width: 102 }}>
            <div
              style={{
                width: 2,
                height: 24,
                background: `linear-gradient(to bottom, ${t.color}60, ${palette.danger}60)`,
              }}
            />
            <div
              style={{
                width: 0,
                height: 0,
                borderLeft: "5px solid transparent",
                borderRight: "5px solid transparent",
                borderTop: `6px solid ${palette.danger}80`,
              }}
            />
          </div>
        ))}
      </div>
      
      {/* Shared instance box */}
      <GlassPanel
        accent={palette.danger}
        glow
        style={{ maxWidth: 720, margin: "0 auto", position: "relative" }}
      >
        <AnimatedBorder color={palette.danger} radius={20} />
        
        <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 18 }}>
          <StatusDot color={palette.danger} />
          <span
            style={{
              fontSize: 12,
              fontWeight: 700,
              color: palette.danger,
              letterSpacing: "0.1em",
              textTransform: "uppercase",
              fontFamily: typography.body,
            }}
          >
            Shared Amazon Connect Instance
          </span>
        </div>
        
        <div
          style={{
            display: "grid",
            gridTemplateColumns: "repeat(auto-fit, minmax(180px, 1fr))",
            gap: 10,
          }}
        >
          {repos.map((r, i) => (
            <div
              key={r.name}
              style={{
                padding: "14px 16px",
                borderRadius: 14,
                border: `1px solid ${palette.borderLight}`,
                background: palette.surface,
                animation: `slideUp 400ms ${easing.outExpo} ${200 + i * 50}ms backwards`,
              }}
            >
              <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 6 }}>
                <span style={{ fontSize: 18 }}>{r.icon}</span>
                <span style={{ fontSize: 12, fontWeight: 700, color: palette.text, fontFamily: typography.body }}>
                  {r.name}
                </span>
              </div>
              <div style={{ fontSize: 11, color: palette.textSecondary, lineHeight: 1.5, fontFamily: typography.body }}>
                {r.desc}
              </div>
              <div style={{ display: "flex", gap: 4, marginTop: 8, alignItems: "center" }}>
                {tenants.map(t => (
                  <span
                    key={t.name}
                    style={{
                      width: 8,
                      height: 8,
                      borderRadius: 3,
                      background: t.color,
                      opacity: 0.8,
                    }}
                  />
                ))}
                <span style={{ fontSize: 9, color: palette.textMuted, marginLeft: 4, fontFamily: typography.mono }}>
                  mixed
                </span>
              </div>
            </div>
          ))}
        </div>
        
        <div
          style={{
            marginTop: 14,
            padding: "12px 16px",
            borderRadius: 12,
            background: palette.dangerDim,
            border: `1px solid ${palette.danger}22`,
            display: "flex",
            alignItems: "flex-start",
            gap: 10,
          }}
        >
          <span style={{ fontSize: 16 }}>⚠️</span>
          <span style={{ fontSize: 12, color: palette.danger, lineHeight: 1.6, fontFamily: typography.body }}>
            Every repository contains commingled data from all tenants. No native partition boundary.
          </span>
        </div>
      </GlassPanel>
    </SlideContainer>
  );
}

// ═══════════════════════════════════════════════════════════════════
// SLIDE 3: TAGGING REALITY
// ═══════════════════════════════════════════════════════════════════

function TaggingSlide({ visible }) {
  const resources = [
    { name: "Users / Agents", taggable: true, tbac: true },
    { name: "Queues", taggable: true, tbac: true },
    { name: "Routing Profiles", taggable: true, tbac: true },
    { name: "Contacts", taggable: false, tbac: false, critical: true },
    { name: "Contact Lens Dashboard", taggable: true, tbac: false, critical: true },
    { name: "Contact Search", taggable: true, tbac: "partial", critical: true },
    { name: "S3 Recordings", taggable: false, tbac: false, critical: true },
    { name: "Kinesis Streams", taggable: false, tbac: false },
    { name: "CloudWatch Logs", taggable: false, tbac: false },
    { name: "Real-time Metrics", taggable: true, tbac: true },
    { name: "Historical Metrics", taggable: true, tbac: true },
    { name: "Security Profiles", taggable: true, tbac: true },
  ];

  return (
    <SlideContainer visible={visible}>
      <GlowOrb color={palette.accent} size={300} top={0} left={-100} opacity={0.06} />
      
      <SectionHeader
        badge="Tagging Matrix"
        badgeColor={palette.warn}
        title="What Tags"
        highlight="Actually Control"
        highlightColor={palette.warn}
        subtitle="TBAC covers operational resources but misses where tenant data lives"
      />
      
      <div style={{ maxWidth: 640, margin: "0 auto", position: "relative", zIndex: 1 }}>
        <GlassPanel padding={0} style={{ overflow: "hidden" }}>
          {/* Header */}
          <div
            style={{
              display: "grid",
              gridTemplateColumns: "1fr 90px 90px",
              padding: "14px 20px",
              background: palette.surfaceElevated,
              borderBottom: `1px solid ${palette.border}`,
            }}
          >
            {["Resource", "Taggable", "TBAC"].map(h => (
              <span
                key={h}
                style={{
                  fontSize: 10,
                  fontWeight: 700,
                  color: palette.textMuted,
                  textTransform: "uppercase",
                  letterSpacing: "0.1em",
                  fontFamily: typography.body,
                  textAlign: h === "Resource" ? "left" : "center",
                }}
              >
                {h}
              </span>
            ))}
          </div>
          
          {/* Rows */}
          {resources.map((r, i) => (
            <div
              key={r.name}
              style={{
                display: "grid",
                gridTemplateColumns: "1fr 90px 90px",
                padding: "12px 20px",
                borderBottom: `1px solid ${palette.border}`,
                background: r.critical ? palette.dangerDim : "transparent",
                animation: `slideUp 250ms ${easing.outExpo} ${i * 30}ms backwards`,
              }}
            >
              <span
                style={{
                  fontSize: 13,
                  color: r.critical ? palette.danger : palette.text,
                  fontWeight: r.critical ? 600 : 400,
                  display: "flex",
                  alignItems: "center",
                  gap: 8,
                  fontFamily: typography.body,
                }}
              >
                {r.critical && <span style={{ fontSize: 10 }}>🚨</span>}
                {r.name}
              </span>
              <span style={{ textAlign: "center", fontSize: 16 }}>
                {r.taggable ? "✅" : "❌"}
              </span>
              <span style={{ textAlign: "center", fontSize: 16 }}>
                {r.tbac === true ? "✅" : r.tbac === "partial" ? "⚠️" : "❌"}
              </span>
            </div>
          ))}
        </GlassPanel>
        
        {/* Critical gap callout */}
        <div
          style={{
            marginTop: 20,
            padding: "18px 22px",
            borderRadius: 16,
            background: `linear-gradient(135deg, ${palette.dangerDim}, ${palette.warnDim})`,
            border: `1px solid ${palette.danger}33`,
            position: "relative",
          }}
        >
          <AnimatedBorder color={palette.danger} radius={16} thickness={1} />
          <div
            style={{
              fontSize: 14,
              fontWeight: 700,
              color: palette.danger,
              marginBottom: 8,
              fontFamily: typography.display,
            }}
          >
            The Critical Gap
          </div>
          <div style={{ fontSize: 13, color: palette.textSecondary, lineHeight: 1.7, fontFamily: typography.body }}>
            <strong style={{ color: palette.text }}>Contacts cannot be tagged.</strong> S3 recordings land 
            in shared buckets. Contact Lens dashboards ignore TBAC. One misconfigured security profile 
            exposes all tenants' data.
          </div>
        </div>
      </div>
    </SlideContainer>
  );
}

