  "Actions": [
    {
      "Identifier": "ChatWelcome",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "👋 Welcome to the Census Survey Chat! I'm here to help collect some information about your household. This should only take a few minutes. Ready to start?"
      },
      "Transitions": {
        "NextAction": "GetChatInput",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "GetChatInput",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "First question: How many people live in your household?",
        "LexBot": {
          "Name": "CensusSurveyBot",
          "Region": "us-east-1",
          "Alias": "$LATEST"
        },
        "LexIntents": [
          {
            "Name": "StartSurvey"
          },
          {
            "Name": "ProvideHouseholdInfo"
          },
          {
            "Name": "ProvideLanguageInfo"
          },
          {
            "Name": "ProvideEmploymentInfo"
          },
          {
            "Name": "ProvideAgeInfo"
          },
          {
            "Name": "ProvideHousingInfo"
          }
        ]
      },
      "Transitions": {
        "NextAction": "SaveChatData",
        "Errors": [
          {
            "NextAction": "EndChat",
            "ErrorType": "NoMatchingError"
          },
          {
            "NextAction": "EndChat",
            "ErrorType": "NoMatchingCondition"
          }
        ],
        "Conditions": []
      }
    },
    {
      "Identifier": "SaveChatData",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "REPLACE_WITH_SURVEY_LAMBDA_ARN",
        "InvocationTimeLimitSeconds": "8",
        "LambdaInvocationAttributes": {
          "household_size": "$.Lex.SessionAttributes.household_size",
          "primary_language": "$.Lex.SessionAttributes.primary_language",
          "employment_status": "$.Lex.SessionAttributes.employment_status",
          "age_range": "$.Lex.SessionAttributes.age_range",
          "housing_type": "$.Lex.SessionAttributes.housing_type",
          "survey_complete": "$.Lex.SessionAttributes.survey_complete",
          "channel": "chat"
        },
        "ResponseValidation": {
          "ResponseType": "STRING_MAP"
        }
      },
      "Transitions": {
        "NextAction": "ChatThankYou",
        "Errors": [
          {
            "NextAction": "EndChat",
            "ErrorType": "NoMatchingError"
          }
        ],
        "Conditions": []
      }
    },
    {
      "Identifier": "ChatThankYou",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "✅ Thank you for completing the census survey! Your responses have been saved. We appreciate your time and participation. Have a wonderful day! 🙏"
      },
      "Transitions": {
        "NextAction": "EndChat",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "EndChat",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    }
  ]
}
